---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  actionLabel?: string;
  actionHref?: string;
}

const { eyebrow, title, description, actionLabel, actionHref } = Astro.props;
---

<div class="section-heading">
  <div>
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h2>{title}</h2>
    {description && <p class="section-description">{description}</p>}
  </div>
  {
    actionLabel && actionHref && (
      <a class="text-link section-action" href={actionHref}>
        {actionLabel}
        <span aria-hidden="true">→</span>
      </a>
    )
  }
</div>
