---
import ExternalArrow from "@/components/ExternalArrow.astro";
import { site } from "@/data/site";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <p class="footer-note">© {year} {site.name}. Views expressed here are my own.</p>
    <ul class="footer-links" aria-label="Profile links">
      {
        site.profiles.slice(0, 4).map((profile) => (
          <li>
            <a
              href={profile.href}
              target={profile.kind === "email" ? undefined : "_blank"}
              rel={profile.kind === "email" ? undefined : "me noopener noreferrer"}
            >
              {profile.label}
              {profile.kind !== "email" && <ExternalArrow />}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>
