---
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import { site } from "@/data/site";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  path?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = site.description,
  path = Astro.url.pathname,
  structuredData,
} = Astro.props;

const pageTitle = title
  ? `${title} — ${site.name}`
  : `${site.name} — Applied Scientist & NLP Researcher`;
const canonical = new URL(path, site.url).href;
const socialImage = new URL("/social-card.png", site.url).href;
const additionalSchema = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];

const personSchema = {
  "@type": "Person",
  "@id": `${site.url}/#person`,
  name: site.name,
  url: site.url,
  image: socialImage,
  jobTitle: "Applied Scientist 2",
  worksFor: {
    "@type": "Organization",
    name: "Microsoft",
    url: "https://www.microsoft.com/",
  },
  alumniOf: [
    {
      "@type": "Organization",
      name: "Microsoft Research India",
    },
    {
      "@type": "CollegeOrUniversity",
      name: "Delhi Technological University",
    },
  ],
  sameAs: site.profiles
    .filter((profile) => profile.kind !== "email")
    .map((profile) => profile.href),
  knowsAbout: [
    "Large language models",
    "Multilingual natural language processing",
    "Continual learning",
    "Model distillation",
    "Parameter-efficient finetuning",
    "Language model evaluation",
  ],
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [personSchema, ...additionalSchema],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content={site.name} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f3efe6" />
    <meta name="color-scheme" content="light" />

    <title>{pageTitle}</title>
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={`${site.name}, Applied Scientist and NLP researcher`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline></script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <SiteHeader currentPath={Astro.url.pathname} />
    <main id="main-content">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
